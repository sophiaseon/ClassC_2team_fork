# Wait for ethernet device to link
for count in 1 2 3 4 5
do
        link=`cat /sys/class/net/eth0/carrier`
        if [ "$link" = "1" ]; then break; fi
        echo "Wait for ethernet device to link - $count"
        sleep 1
done

mknod /dev/mydev c 120 0
mount -t nfs -o nolock 192.168.10.2:/nfsroot /mnt/nfs
telnetd

/sbin/insmod /root/devtest.ko
/sbin/insmod /root/luxtest.ko
/sbin/insmod /root/ultrasonic.ko

if [ -f /mnt/nfs/host_time.txt ]; then
	host_time=$(cat /mnt/nfs/host_time.txt)
	if [ -n "$host_time" ]; then
		date -s "$host_time"
	fi
fi

export HOME=/root

sleep 1
/root/Bootcamp -platform linuxfb > /tmp/bootcamp.log 2>&1 &


